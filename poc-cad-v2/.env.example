# ============================================================================
# CAD Generation API - Environment Configuration
# Gemini Vision to Rhino CAD Architecture
# ============================================================================

# --- FastAPI Server Configuration ---
ENVIRONMENT=development
DEBUG=true
API_PORT=8000
API_HOST=0.0.0.0
LOG_LEVEL=INFO

# --- Database Configuration ---
DATABASE_URL=postgresql://user:password@localhost:5432/cad_db
REDIS_URL=redis://localhost:6379

# --- Authentication ---
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- Google Gemini API Configuration ---
# Get API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_MAX_TOKENS=4096

# --- Rhino Compute Configuration (Windows 10 Pro) ---
# Local Rhino Compute URL (before Cloudflare tunnel)
RHINO_COMPUTE_LOCAL_URL=http://localhost:8081

# Cloudflare Tunnel URL (secure remote access)
RHINO_COMPUTE_URL=https://rhino-api.yourdomain.com

# Optional: API key for Rhino Compute (if authentication is enabled)
RHINO_COMPUTE_API_KEY=optional_rhino_api_key

# Rhino Compute timeout in seconds
RHINO_COMPUTE_TIMEOUT=60

# Default Grasshopper definition to use
RHINO_DEFAULT_DEFINITION=default_parametric_model

# --- File Upload Configuration ---
UPLOAD_MAX_FILE_SIZE=52428800  # 50MB
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,gif,webp
UPLOAD_DIRECTORY=./uploads

# --- CAD Output Configuration ---
CAD_OUTPUT_DIRECTORY=./cad_models
STL_OUTPUT_FORMAT=stl
KEEP_TEMPORARY_FILES=false

# --- CORS Configuration ---
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000,https://yourdomain.com
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization

# --- Logging Configuration ---
LOG_FILE=./logs/api.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# --- Feature Flags ---
ENABLE_BATCH_PROCESSING=true
ENABLE_STL_VALIDATION=true
ENABLE_METRIC_COLLECTION=true
CACHE_GRASSHOPPER_DEFINITIONS=true

# --- Performance Tuning ---
WORKER_THREADS=4
REQUEST_TIMEOUT_SECONDS=300
MAX_CONCURRENT_JOBS=10

# --- Monitoring & Analytics ---
SENTRY_DSN=optional_sentry_dsn_for_error_tracking
ENABLE_PROMETHEUS_METRICS=false

# --- Email Configuration (for notifications) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@yourdomain.com

# --- S3/Cloud Storage (optional) ---
# AWS_S3_BUCKET=your_bucket_name
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ============================================================================
# IMPORTANT: NEVER COMMIT THIS FILE WITH REAL SECRETS
# Use .env.local for development secrets
# ============================================================================
